# Required
ANTHROPIC_API_KEY=sk-ant-...

# Per-project signing secret from Dovilo (Project editor → Webhooks →
# "Generate signing secret"). The plaintext is shown only once — copy it
# straight here. If unset, signature verification is DISABLED (dev only,
# not safe for anything else).
DOVILO_WEBHOOK_SECRET=

# Optional — override the MCP config location (defaults to ./.mcp.json)
# DOVILO_MCP_CONFIG=.mcp.json

# Optional — which entry inside mcpServers to use (defaults to "Dovilo")
# DOVILO_MCP_SERVER_NAME=Dovilo

# Optional — override the auto-detected list-tasks MCP tool
# DOVILO_LIST_TASKS_TOOL=list_tasks

# Note: the Dovilo MCP API key lives inside .mcp.json -> mcpServers.Dovilo.env,
# the same place Claude Code reads it from. No duplication needed here.
